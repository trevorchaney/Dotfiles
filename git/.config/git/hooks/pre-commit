#!/bin/sh
# Author: Trevor Chaney
# Email: trevorchaney@gmail.com
# Website: https://tlc.is
# Remotes: https://github.com/trevorchaney/Dotfiles
# Generated by git/update-backlinks.sh
# Improved pre-commit hook
# - scans staged hunks for markers
# - `@do-not-commit` in any added line aborts the commit
# - `@review` in any added line prompts the user to accept the hunk interactively
# - in non-interactive environments (CI) any `@review` will abort the commit

# Examples:
# 1) Prevent accidental commits:
#    If a staged hunk contains an added line like:
#      + // @do-not-commit - placeholder until reviewed
#    the hook will abort the commit and print the offending hunk.
#
# 2) Request interactive review for a hunk:
#    If a staged hunk contains an added line like:
#      + // @review - please validate this change
#    the hook will show the hunk and ask to Accept this hunk for commit? [y/N]
#    In CI (non-interactive) the presence of `@review` will cause the commit to abort.

set -eu

MARKER_BLOCK='@do-not-commit'
MARKER_REVIEW='@review'

TMPDIR=$(mktemp -d 2>/dev/null || mktemp -d /tmp/diffhooks.XXXXXX)
cleanup() { rm -rf "$TMPDIR"; }
trap cleanup EXIT

# Only consider added/modified/copied files (skip deletions)
# Write NUL-separated list to a temp file (avoid storing NULs in a shell variable)
git diff --cached --name-only -z --diff-filter=ACM > "$TMPDIR/staged.list"
[ ! -s "$TMPDIR/staged.list" ] && exit 0

echo "pre-commit: scanning staged hunks for markers..."

# Collect full staged diff and scan for markers directly.
DIFF=$(git diff --cached -U0 --diff-filter=ACM || true)

# Check for blocking marker (@do-not-commit) in added lines
if printf "%s" "$DIFF" | grep -Eq '^\+.*'"$MARKER_BLOCK"; then
  echo
  echo "ERROR: Found '$MARKER_BLOCK' in staged added lines:"
  printf "%s" "$DIFF" | grep -n --color=always '^\+.*'"$MARKER_BLOCK" || true
  echo "Commit aborted. Remove the marker or unstaged that hunk."
  exit 1
fi

# Check for review marker (@review)
if printf "%s" "$DIFF" | grep -Eq '^\+.*'"$MARKER_REVIEW"; then
  echo
  echo "REVIEW REQUIRED for staged changes:"
  printf "%s" "$DIFF" | grep -n --color=always '^\+.*'"$MARKER_REVIEW" || true
  if [ -t 0 ]; then
    printf "Accept all hunks containing '%s' for commit? [y/N]: " "$MARKER_REVIEW"
    read ans || ans=""
    case "$ans" in
      y|Y) echo "Accepted." ;;
      *) echo "Commit aborted."; exit 1 ;;
    esac
  else
    echo "Non-interactive shell (CI). '@review' marker causes commit to abort." 
    exit 1
  fi
fi

exit 0
