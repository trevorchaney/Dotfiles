#!/bin/sh
# Author: Trevor Chaney
# Email: trevorchaney@gmail.com
# Website: https://tlc.is
# Remotes: https://github.com/trevorchaney/Dotfiles
# Generated by git/update-backlinks.sh
# commit-msg hook: basic sanity checks for commit message
# - non-empty subject
# - subject length <= 72 chars
# - disallow @do-not-commit marker in message

# Examples:
# Good subject: "feat(cli): add --quiet flag"
# Bad subject (too long): "A very long subject that is longer than seventy-two characters and will be rejected"
# Marker block: if your commit message contains the literal string `@do-not-commit` the hook will abort.

MSGFILE="$1"
[ -f "$MSGFILE" ] || exit 0

SUBJECT=$(sed -n '1p' "$MSGFILE" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
if [ -z "$SUBJECT" ]; then
  echo "Aborting commit: empty commit subject is not allowed." >&2
  exit 1
fi

# Check subject length (bytes). Adjust if you prefer characters.
if [ $(printf "%s" "$SUBJECT" | wc -c) -gt 72 ]; then
  echo "Aborting commit: commit subject is longer than 72 characters (length=$(printf '%s' "$SUBJECT" | wc -c))." >&2
  exit 1
fi

if grep -q '@do-not-commit' "$MSGFILE"; then
  echo "Aborting commit: commit message contains @do-not-commit marker." >&2
  exit 1
fi

exit 0
