#!/bin/bash
# Author: Trevor Chaney
# Email: trevorchaney@gmail.com
# Website: https://tlc.is
# Remotes: https://github.com/trevorchaney/Dotfiles
# Generated by git/update-backlinks.sh
# ref: https://stackoverflow.com/questions/5894946/how-to-add-gits-branch-name-to-the-commit-message

# Examples:
# 1) Branch contains ticket (JIRA-style):
#    Branch: FEATURE-123_add-login
#    Subject: "Add login handler"
#    Result: footer appended: "Ticket: FEATURE-123"
#
# 2) GitHub-style issue reference in branch or subject:
#    Branch: feature/login-#42
#    Subject: "Fix OAuth bug (#42)"
#    If `git config hooks.prepare-commit-msg.addLink true` and `origin` is GitHub,
#    hook will append `Ticket: #42` and `Ticket URL: https://github.com/owner/repo/issues/42`.
#
# 3) No ticket found:
#    In interactive shells you'll be prompted to optionally enter one; in CI the hook will skip silently.

COMMIT_MSG_FILE=$1
COMMIT_MSG_SOURCE=${2:-}

# Configuration: if set to 'true' (git config or env var), try to add issue links for GitHub
# Example to enable: git config hooks.prepare-commit-msg.addLink true
ADD_LINK=$(git config --bool hooks.prepare-commit-msg.addLink 2>/dev/null || echo false)

is_interactive=0
[ -t 0 ] && is_interactive=1

read_file() { cat "$COMMIT_MSG_FILE"; }

find_ticket() {
    # Try several patterns in order: JIRA (ABC-123), GitHub (#123), explicit 'ticket 123' or 'RT#123'
    local text="$1"
    # JIRA-like: PROJECT-123
    if printf "%s" "$text" | grep -Eo '\b[A-Z][A-Z0-9]+-[0-9]+\b' | head -n1 >/dev/null 2>&1; then
        printf "%s" "$(printf "%s" "$text" | grep -Eo '\b[A-Z][A-Z0-9]+-[0-9]+\b' | head -n1)"
        return 0
    fi
    # GitHub issue: #123 (avoid matching C-style numbers like 'C#')
    if printf "%s" "$text" | grep -Eo '(?<![A-Za-z0-9])#[0-9]{1,6}\b' | head -n1 >/dev/null 2>&1; then
        printf "%s" "$(printf "%s" "$text" | grep -Eo '(?<![A-Za-z0-9])#[0-9]{1,6}\b' | head -n1)"
        return 0
    fi
    # Other common forms: 'ticket 123', 'RT#123'
    if printf "%s" "$text" | grep -Eo '\b(?:ticket|Ticket|RT)[:# ]*[0-9]{1,6}\b' | head -n1 >/dev/null 2>&1; then
        printf "%s" "$(printf "%s" "$text" | grep -Eo '\b(?:ticket|Ticket|RT)[:# ]*[0-9]{1,6}\b' | head -n1)"
        return 0
    fi
    return 1
}

normalize_ticket() {
    # Normalize captured ticket text to a compact form (no surrounding words)
    local t="$1"
    # Trim
    t=$(printf "%s" "$t" | sed 's/^\s*//;s/\s*$//')
    printf "%s" "$t"
}

already_has_ticket() {
    # Check if message already contains a 'Ticket:' footer or ticket-like string
    if read_file | grep -Eqi '^Ticket:'; then
        return 0
    fi
    if read_file | grep -Eqi '\b[A-Z][A-Z0-9]+-[0-9]+\b|(?<![A-Za-z0-9])#[0-9]{1,6}\b'; then
        return 0
    fi
    return 1
}

append_ticket_footer() {
    local ticket="$1"
    local url="$2"
    # Avoid duplicating
    if read_file | grep -F -q "Ticket: $ticket"; then
        return 0
    fi
    if [ -n "$url" ]; then
        printf "\n\nTicket: %s\nTicket URL: %s\n" "$ticket" "$url" >> "$COMMIT_MSG_FILE"
    else
        printf "\n\nTicket: %s\n" "$ticket" >> "$COMMIT_MSG_FILE"
    fi
}

# If commit message already references a ticket, do nothing.
if already_has_ticket; then
    exit 0
fi

# Gather searchable text: branch name, subject, and body
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)
SUBJECT=$(sed -n '1p' "$COMMIT_MSG_FILE" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
BODY=$(sed '1,/^$/d' "$COMMIT_MSG_FILE" || true)

# Try to find in branch first, then subject, then body
TICKET=""
for src in "$BRANCH" "$SUBJECT" "$BODY"; do
    if [ -n "$src" ]; then
        found=$(find_ticket "$src" 2>/dev/null || true)
        if [ -n "$found" ]; then
            TICKET=$(normalize_ticket "$found")
            break
        fi
    fi
done

# If not found, and interactive, prompt the user to optionally provide one
if [ -z "$TICKET" ] && [ "$is_interactive" -eq 1 ]; then
    printf "No ticket reference found in branch/commit. Enter ticket id to associate (or leave blank to skip): "
    read user_ticket || user_ticket=""
    TICKET=$(normalize_ticket "$user_ticket")
fi

# If still empty, nothing to do
[ -z "$TICKET" ] && exit 0

# Optionally try to construct a GitHub issue URL if the ticket is a simple #123 and remote is GitHub
TICKET_URL=""
if printf "%s" "$TICKET" | grep -Eq '^#[0-9]+'; then
    if [ "$ADD_LINK" = "true" ]; then
        origin_url=$(git remote get-url origin 2>/dev/null || true)
        if printf "%s" "$origin_url" | grep -qi 'github.com'; then
            # Convert git@github.com:owner/repo.git or https://github.com/owner/repo.git
            owner_repo=$(printf "%s" "$origin_url" | sed -E 's#.*github.com[:/]+([^/]+/[^/.]+)(\.git)?#\1#')
            if [ -n "$owner_repo" ]; then
                num=$(printf "%s" "$TICKET" | sed 's/#//')
                TICKET_URL="https://github.com/$owner_repo/issues/$num"
            fi
        fi
    fi
fi

# Append as non-enforcing footer
append_ticket_footer "$TICKET" "$TICKET_URL"

exit 0
