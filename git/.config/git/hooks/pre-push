#!/bin/sh
# Author: Trevor Chaney
# Email: trevorchaney@gmail.com
# Website: https://tlc.is
# Remotes: https://github.com/trevorchaney/Dotfiles
# Generated by git/update-backlinks.sh
# pre-push hook: warn / protect pushes to 'master' or 'main'
# If an attempt is made to push to master/main, prompt to confirm when interactive.
# In non-interactive environments, reject the push.

# Examples:
# - Interactive local push to protected branch:
#     Attempting to push to protected branch: refs/heads/master
#     Allow push to refs/heads/master? [y/N]:
#   Choose 'y' to allow, anything else aborts the push.
# - In CI, pushes to master/main will be rejected by this hook.

interactive=0
[ -t 0 ] && interactive=1

warned=0
while read local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/master|refs/heads/main)
      echo "Attempting to push to protected branch: $remote_ref"
      warned=1
      if [ "$interactive" -eq 1 ]; then
        printf "Allow push to $remote_ref? [y/N]: "
        read ans || ans=""
        case "$ans" in
          y|Y) echo "Allowed." ;;
          *) echo "Push aborted by pre-push hook."; exit 1 ;;
        esac
      else
        echo "Non-interactive environment: push to $remote_ref is blocked by hook." >&2
        exit 1
      fi
      ;;
  esac
done

if [ "$warned" -eq 0 ]; then
  exit 0
fi

exit 0
